---
import Button from "../../components/ui/Button.astro";
import { Image } from "astro:assets";
import neonCircles from "../../assets/index/codezone-neon-circles.webp";
import logo from "../../assets/svg/codezone-logo-header-neon.svg";
---

<section
  id="hero"
  class="relative pt-20 md:pt-30 lg:pt-35  max-w-480 mx-auto md:min-h-112 lg:min-h-194 overflow-hidden rounded-b-3xl md:rounded-b-4xl"
>
  <div
    class="header-container relative z-1 flex flex-col-reverse max-w-(--width-max-content) mx-auto md:flex-row items-center justify-center md:justify-between gap-6 xl:gap-11 px-2 md:px-4 xl:px-6"
  >
    <article
      class="w-full lg:w-6/10 text-center md:text-left overflow-visible flex flex-col justify-center items-center md:items-start gap-3 lg:gap-8 xl:gap-2"
    >
      <h2
        class="hero-title font-sans font-medium"
        style="font-size: clamp(2.25rem, 1.4712rem + 3.4615vw, 5.625rem);"
      >
        <span class="hero-title-first block leading-none">Hacemos realidad</span
        >
        <span class="hero-title-second leading-none">tu idea digital</span>
      </h2>

      <h1
        class="hero-subtitle font-sans font-medium text-cyan-300 mx-5 md:mx-0 leading-tight xl:leading-10 2xl:pr-20"
      >
        Desarrollo de páginas web, software a medida e integración de sistemas
        (APIs)
      </h1>

      <div
        class="hero-cta inline-flex w-full md:w-auto justify-center md:justify-start mt-7 lg:mt-10"
      >
        <Button href="#contact-separator" variant="solid" size="small">
          Hablemos de tu proyecto
        </Button>
      </div>
    </article>
    <article
      class="w-75 h-71 lg:w-full lg:h-auto flex justify-center md:justify-end max-w-138 mx-auto relative"
    >
      <div class="circles-wrapper relative mx-auto aspect-271/256">
        <div class="capa-stack neon-circles-wrapper grid place-items-center">
          <Image
            src={neonCircles}
            alt=""
            aria-hidden="true"
            class="neon-circle-img"
            width={452}
            height={427}
            widths={[400, 452, 800, 1200]}
            sizes="(max-width: 768px) 100vw, 452px"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            priority
          />
        </div>

        <div
          class="capa-stack absolute inset-0 place-items-center grid z-10 animation-circles-container"
        >
          {/* Base Logo (Static) */}
          <Image
            class="logo-base xl:w-57.5 xl:h-28.75 w-37.5 h-18.75 relative z-10"
            src={logo}
            alt="Logo de CodeZone con iniciales C y Z"
            width={230}
            height={115}
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
          {/* Glow Layer (Pulsing Opacity) */}
          <Image
            class="logo-glow-layer xl:w-57.5 xl:h-28.75 w-37.5 h-18.75 absolute z-0"
            src={logo}
            alt=""
            aria-hidden="true"
            width={230}
            height={115}
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </div>
      </div>
    </article>
  </div>
</section>

<style>
  /* #hero {
    background-image: url("/images/bg-pages/bg-index.webp");
    background-size: cover;
    background-position: left center;
    background-repeat: no-repeat;
  } */

  #hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("/images/bg-pages/bg-index.webp");
    background-size: cover;
    background-position: left center;
    background-repeat: no-repeat;
    z-index: -1;
  }

  .hero-subtitle {
    font-size: clamp(1.125rem, 0.8077rem + 1.4103vw, 2.5rem);
    line-height: 1.3;
  }

  .neon-circle-img {
    width: 100%;
    max-width: 550px;
    height: auto;
    object-fit: cover;
    animation: rotate-animation 6s infinite linear;
    z-index: 0;
    will-change: transform;
    transform: translateZ(0);
  }
  
  .logo-base {
    filter: drop-shadow(0 0 12px rgba(200, 0, 222, 0.4));
  }

  .logo-glow-layer {
    filter: drop-shadow(0 0 24px var(--fuchsia-600))
      drop-shadow(0 0 45px rgba(200, 0, 222, 0.6));
    animation: glow-pulse 3s cubic-bezier(0.39, 0.575, 0.565, 1) infinite;
    animation-play-state: paused;
  }

  @keyframes glow-pulse {
    0%,
    100% {
      opacity: 0;
    }
    50% {
      opacity: 1;
    }
  }

  .logo-base path[stroke="black"],
  .logo-glow-layer path[stroke="black"] {
    stroke: #111;
  }


  .circles-wrapper {
    display: grid;
    grid-template-areas: "stack";
    isolation: isolate;
    aspect-ratio: 271 / 256;
  }

  /* .animation-circles-container,
  .neon-circles-wrapper {
    opacity: 0;
    transform: scale(0.95);
  } */

    @media (max-width: 768px) {
    #hero {
      height: 100svh;
      min-height: 100svh;
      max-height: none;
      display: flex;
      align-items: flex-start;
      justify-content: center;
      padding-top: 5.025rem;
    }

    /* Reducir capas GPU en mobile para evitar jank en scroll */
    .hero-subtitle,
    .hero-cta,
    .logo-base,
    .logo-glow-layer,
    .neon-circle-img {
      will-change: auto;
    }
  }


  @keyframes rotate-animation {
    from {
      transform: translateZ(0) rotate(0deg);
    }
    to {
      transform: translateZ(0) rotate(360deg);
    }
  }

  @media (width <= 1024px) {
    .logo-base,
    .logo-glow-layer {
      width: 140px;
      height: auto;
    }
  }

  @media (width <= 768px) {
    .logo-base,
    .logo-glow-layer {
      width: 130px;
      height: auto;
    }
  }
</style>
