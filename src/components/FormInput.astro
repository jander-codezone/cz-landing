---
import type { FormInputProps } from "../types/components";

interface Props extends FormInputProps {}

const {
  type = "text",
  name,
  label,
  placeholder = "",
  error = "",
  value = "",
} = Astro.props;

const inputId = `input-${name}`;
const errorId = `error-${name}`;
const hasError = error && error.length > 0;
---

<div class="form-input-wrapper">
  <label for={inputId} class="form-label">
    {label}
    {name !== "message" && <span class="text-red-400">*</span>}
  </label>

  {
    type === "textarea" ? (
      <textarea
        id={inputId}
        name={name}
        placeholder={placeholder}
        autocomplete="off"
        aria-invalid={hasError ? "true" : "false"}
        aria-describedby={hasError ? errorId : undefined}
        class:list={["form-textarea", { "form-input-error": hasError }]}
      >{value}</textarea>
    ) : (
      <input
        id={inputId}
        type={type}
        name={name}
        placeholder={placeholder}
        value={value}
        autocomplete="off"
        aria-invalid={hasError ? "true" : "false"}
        aria-describedby={hasError ? errorId : undefined}
        class:list={["form-input", { "form-input-error": hasError }]}
      />
    )
  }

  {
    hasError && (
      <span id={errorId} class="form-error" role="alert" aria-live="polite">
        {error}
      </span>
    )
  }
</div>

<style>
  .form-input-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
  }

  .form-label {
    font-size: 0.875rem;
    color: #f5f5f5;
    font-weight: 500;
    text-align: left;
    margin-bottom: 0.25rem;
    margin-left: 0.25rem;
  }

  .form-input,
  .form-textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    background: transparent;
    border: 2px solid rgba(83, 233, 253, 0.3);
    color: #fcfcfc;
    font-size: 1rem;
    transition: all 300ms ease;
    outline: none;
    resize: none;
  }

  .form-input {
    border-radius: 32px;
  }

  .form-textarea {
    min-height: 120px;
    resize: vertical;
    font-family: inherit;
    border-radius: 24px;
  }

  .form-input:focus,
  .form-textarea:focus {
    border-color: var(--cyan-300);
  }

  .form-input-error {
    border-color: rgb(239, 68, 68) !important;
  }

  .form-error {
    font-size: 0.875rem;
    color: rgb(239, 68, 68);
    margin-top: -0.25rem;
  }

  .form-input::placeholder,
  .form-textarea::placeholder {
    color: rgba(212, 212, 212, 0.5);
  }

  /* Prevent background color change on autocomplete */
  .form-input:-webkit-autofill,
  .form-input:-webkit-autofill:hover,
  .form-input:-webkit-autofill:focus,
  .form-input:-webkit-autofill:active,
  .form-textarea:-webkit-autofill,
  .form-textarea:-webkit-autofill:hover,
  .form-textarea:-webkit-autofill:focus,
  .form-textarea:-webkit-autofill:active {
    -webkit-box-shadow: 0 0 0 30px var(--primary-blue) inset !important;
    -webkit-text-fill-color: #fcfcfc !important;
    caret-color: #fcfcfc;
    transition: background-color 5000s ease-in-out 0s;
    border: 2px solid rgba(83, 233, 253, 0.3);
  }

  /* Ensure focus border color takes precedence even when autofilled */
  .form-input:-webkit-autofill:focus,
  .form-textarea:-webkit-autofill:focus {
    border-color: var(--cyan-300) !important;
  }
</style>
