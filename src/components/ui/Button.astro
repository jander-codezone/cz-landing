---
interface Props {
  variant?: "outline" | "solid";
  size?: "small" | "medium" | "large";
  href?: string;
  type?: "button" | "submit" | "reset";
  icon?: string;
  className?: string;
  ariaLabel?: string;
  disabled?: boolean;
  hoverColor?: string;
}

const {
  variant = "solid",
  size = "small",
  href,
  type = "button",
  icon,
  className,
  ariaLabel,
  disabled = false,
  hoverColor = "var(--cyan-300)",
} = Astro.props;

const sizes = {
  small: "px-4 py-2 text-sm",
  medium: "px-4 py-3 text-base",
  large: "px-4.5 py-4 text-lg",
};
---

{
  href ? (
    <a
      href={href}
      class:list={["btn", `btn-${variant}`, sizes[size], className]}
      aria-label={ariaLabel}
      aria-disabled={disabled ? "true" : undefined}
      tabindex={disabled ? -1 : undefined}
      style={{ "--btn-hover-color": hoverColor }}
    >
      <slot />
      {icon && (
        <span
          class="w-5 h-5 inline-block bg-current transition-colors"
          style={{
            maskImage: `url(/${icon})`,
            WebkitMaskImage: `url(/${icon})`,
            maskSize: "contain",
            WebkitMaskSize: "contain",
            maskRepeat: "no-repeat",
            WebkitMaskRepeat: "no-repeat",
            maskPosition: "center",
            WebkitMaskPosition: "center",
          }}
          role="img"
          aria-label="icono de flecha"
        />
      )}
      <slot name="icon" />
    </a>
  ) : (
    <button
      type={type}
      class:list={["btn", `btn-${variant}`, sizes[size], className]}
      aria-label={ariaLabel}
      disabled={disabled}
      style={{ "--btn-hover-color": hoverColor }}
    >
      <slot />
      {icon && (
        <span
          class="w-5 h-5 inline-block bg-current transition-colors"
          style={{
            maskImage: `url(/${icon})`,
            WebkitMaskImage: `url(/${icon})`,
            maskSize: "contain",
            WebkitMaskSize: "contain",
            maskRepeat: "no-repeat",
            WebkitMaskRepeat: "no-repeat",
            maskPosition: "center",
            WebkitMaskPosition: "center",
          }}
          role="img"
          aria-label="icono de flecha"
        />
      )}
      <slot name="icon" />
    </button>
  )
}

<style>
  .btn {
    display: inline-flex;
    gap: 8px;
    justify-content: center;
    align-items: center;
    text-decoration: none;
    font-weight: 500;
    color: var(--light-gray);
    border-radius: 100px;
    white-space: nowrap;
    cursor: pointer;
    position: relative;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
    transition:
      transform var(--transition-fast),
      opacity var(--transition-fast);
  }

  /* Focus state - WCAG 2.1 AA compliant */
  .btn:focus-visible {
    outline: 2px solid var(--cyan-300);
    outline-offset: 4px;
  }

  /* Active state - tactile feedback */
  .btn:active {
    transform: scale(0.98);
  }

  /* Disabled state */
  .btn:disabled,
  .btn[aria-disabled="true"] {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* background: var(--cz-default-gradient, linear-gradient(90deg, #C800DE 0%, #53EAFD 100%)); */
  .btn-outline {
    background: transparent;
    background-image:
      linear-gradient(90deg, var(--primary-blue) 0%, var(--primary-blue) 50%),
      var(--cz-border-gradient);
    background-clip: padding-box, border-box;
    background-origin: border-box;
    background-position: center left;
    background-size: 200% 200%;
    border: 2px solid transparent;
    transition:
      background-position var(--transition-slow),
      color var(--transition-slow),
      transform var(--transition-fast),
      opacity var(--transition-fast);
    /* padding: 12px 16px; */
  }

  .btn-outline:hover {
    background-position: center right;
    color: var(--btn-hover-color);
  }

  /* Ensure active state works with hover */
  .btn-outline:active {
    transform: scale(0.98);
  }

  .btn-solid {
    background-image: linear-gradient(
      90deg,
      var(--fuchsia-600) 10%,
      var(--cyan-300) 50%,
      var(--fuchsia-600) 90%
    );
    background-position: center left;
    background-size: 200% 200%;
    transition:
      background-position var(--transition-slow),
      transform var(--transition-fast),
      opacity var(--transition-fast);
  }

  .btn-solid:hover {
    background-position: center right;
  }

  /* Ensure active state works with hover */
  .btn-solid:active {
    transform: scale(0.98);
  }

  @media (prefers-reduced-motion: reduce) {
    .btn-outline,
    .btn-solid {
      transition: none;
      background-position: center right;
    }
  }

  @media (hover: none) {
    .btn-outline:hover,
    .btn-solid:hover {
      background-position: center left;
    }
  }

  @media screen and (max-width: 480px) {
    .btn {
      width: auto;
      justify-content: center;
    }

    /* Mantener padding mínimo 16x12 y máximo 16x18 en mobile */
    .btn-outline,
    .btn-solid {
      min-width: fit-content;
    }

    /* Para botones large en mobile, usar padding máximo
    .btn.px-8 {
      padding: 16px 18px;
      height: 42px;
    } */
  }
</style>
