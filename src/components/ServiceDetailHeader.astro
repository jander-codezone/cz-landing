---
import GradientText from "./GradientText.astro";

interface Props {
    idServiceDetail?: string;
    title: string;
    subtitle?: string;
    classChildren?: string;
}

const { idServiceDetail, title, subtitle, classChildren } = Astro.props;
const linePointImg = "/images/utils/line-point.webp";
const linePointMobileImg = "/images/utils/separador-point-mobile.svg";
---

<section
    id={idServiceDetail}
    class={!subtitle
        ? "scroll-mt-24 md:scroll-mt-28 max-w-(--width-max-content) mx-auto mt-24 md:mt-32 lg:mt-40 flex flex-col justify-start items-center gap-0 md:gap-6 lg:gap-8"
        : "mx-auto mt-0 mb-24 md:mb-32 lg:mb-40 flex flex-col justify-start items-center gap-0 md:gap-6 lg:gap-8"}
>
    <div
        class={`max-w-[${subtitle ? "--width-max-content" : "769px"}] flex flex-col justify-start items-center`}
    >
        {
            subtitle && (
                <h2 class="text-cyan-300 font-medium text-center text-lg lg:text-2xl xl:text-2xl py-0 lg:pb-1.5 lg:leading-7">
                    {subtitle}
                </h2>
            )
        }
        <GradientText
            as="h2"
            gradient="purple-cyan"
            className="text-3xl md:text-4xl lg:text-5xl font-medium text-center pb-0 lg:pb-1.5 lg:leading-12"
        >
            {title}
        </GradientText>
        <picture class="-mt-3">
            <source media="(min-width: 768px)" srcset={linePointImg} />
            <img src={linePointMobileImg} alt="line-point" width="100%" height="100%" loading="lazy" />
        </picture>
    </div>
    <div class={classChildren}>
        <slot />
    </div>
</section>
