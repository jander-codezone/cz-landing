---
import { Image } from "astro:assets";
import type { NavItem } from "../data/navigation";
import Button from "./ui/Button.astro";
import Logo from "../assets/svg/codezone-logo-color.svg";

interface Props {
  navItems: NavItem[];
  logoSrc?: string;
}

const { navItems, logoSrc = Logo } = Astro.props;
---

<button
  id="mobilemenu-burger"
  class="mobilemenu-burger"
  aria-label="Abrir menú"
  aria-expanded="false"
  aria-controls="mobilemenu-overlay"
  type="button"
>
  <div
    id="mobilemenu-burger-icon"
    class="mobilemenu-burger-icon"
    aria-hidden="true"
  >
    <span class="line"></span>
    <span class="line"></span>
    <span class="line"></span>
  </div>
</button>

<div
  id="mobilemenu-overlay"
  class="mobilemenu-overlay relative -z-10"
  aria-hidden="true"
  inert
  role="dialog"
  aria-modal="true"
  aria-label="Menú de navegación móvil"
>
  <!-- Logo CodeZone - Fixed position top left -->
  <div class="mobilemenu-header">
    <a class="mobilemenu-logo" href="/#hero">
       <Image
        src={Logo}
        alt="Logo de CodeZone - Ir a inicio"
        width={180}
        height={26}
        widths={[360, 640, 750, 1080, 1280, 1440, 1920, 2560]}
        sizes="(max-width: 768px) 100vw, 609px"
        priority
        decoding="async"
        class="w-35 h-6.5 block"
      />
    </a>
  </div>

  <!-- Menu items centered -->
  <div id="mobilemenu-items" class="mobilemenu-items">
    <!-- Navigation Links -->
    <ul class="mobilemenu-list">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="mobilemenu-item"
              aria-current={item.isActive ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Contact CTA -->
    <div class="mobilemenu-cta-wrapper">
      <Button
        href="/#contact-separator"
        variant="outline"
        size="small"
        icon="icon-images/svg/icon-arrow.svg"
        className="mobilemenu-cta"
      >
        Contacto
      </Button>
    </div>
  </div>
</div>

<script>
  /* @ts-nocheck */

  // Defer loading of the navigation manager until it's actually needed
  // to reduce initial JS critical path. We'll dynamically import it on first use.
  let _navManager: any = null;
  async function getNavManager(): Promise<any> {
    if (_navManager) return _navManager;
    _navManager = await import("../utils/navigation/navigation-manager");
    return _navManager;
  }

  document.addEventListener("astro:page-load", () => {
    const burgerBtn = document.getElementById("mobilemenu-burger");
    const burgerIcon = document.getElementById("mobilemenu-burger-icon");
    const overlay = document.getElementById("mobilemenu-overlay");
    const logo = document.querySelector(".mobilemenu-logo");

    // Select animated items: menu items and CTA (logo stays fixed, no animation)
    const menuItems = document.querySelectorAll(
      ".mobilemenu-item, .mobilemenu-cta",
    );
    const allAnimatedItems = Array.from(menuItems);

    let isMenuOpen = false;

    // Overlay and animation timing
    const overlayTransitionDuration = 400; // ms - should match CSS
    const itemAnimationDuration = 90;

    /**
     * Anima los items del menú con efecto escalonado.
     * Aplica transformaciones y opacidad a cada item con un delay incremental
     * para crear un efecto de cascada visual.
     *
     * @param {boolean} isOpening - true si el menú se está abriendo, false si se está cerrando
     * @returns {void}
     */
    function animateMenuItems(isOpening: boolean): void {
      const elements = Array.from(allAnimatedItems);
      if (!isOpening) elements.reverse();

      elements.forEach((item, index) => {
        const delay = index * itemAnimationDuration;
        setTimeout(() => {
          const el = item as HTMLElement;
          if (isOpening) {
            el.style.transform = "translateY(0px)";
            el.style.opacity = "1";
          } else {
            el.style.transform = "translateY(10px)";
            el.style.opacity = "0";
          }
        }, delay);
      });
    }

    /**
     * Alterna el estado abierto/cerrado del menú móvil.
     * Maneja animaciones, actualiza atributos ARIA, gestiona el overflow del body,
     * y maneja el foco del teclado para accesibilidad.
     *
     * @returns {void}
     */
    function toggleMenu(): void {
      isMenuOpen = !isMenuOpen;

      if (burgerIcon) burgerIcon.classList.toggle("active", isMenuOpen);
      if (burgerBtn)
        burgerBtn.setAttribute("aria-expanded", String(isMenuOpen));

      if (isMenuOpen) {
        if (overlay) {
          overlay.classList.add("visible");
          overlay.setAttribute("aria-hidden", "false");
          try {
            (overlay as any).inert = false;
          } catch (e) {
            /* ignore if not supported */
          }
        }

        // Prevent body scroll (no padding compensation needed on mobile)
        document.body.style.overflow = "hidden";

        setTimeout(() => {
          animateMenuItems(true);
          // focus first menu item for keyboard users
          const first = document.querySelector(
            ".mobilemenu-item",
          ) as HTMLElement | null;
          if (first) first.focus();
        }, overlayTransitionDuration);
      } else {
        animateMenuItems(false);
        const totalItemDuration =
          allAnimatedItems.length * itemAnimationDuration;

        setTimeout(() => {
          if (overlay) {
            overlay.classList.remove("visible");
            overlay.setAttribute("aria-hidden", "true");
            try {
              (overlay as any).inert = true;
            } catch (e) {
              /* ignore */
            }
          }

          // Restore body scroll
          document.body.style.overflow = "";

          // Return focus to burger button
          try {
            const active = document.activeElement as Element | null;
            if (active && overlay && overlay.contains(active)) {
              if (burgerBtn) {
                (burgerBtn as HTMLElement).focus();
              } else {
                (document.body as HTMLElement).focus();
              }
            }
          } catch (e) {
            /* ignore focus handling errors */
          }
        }, totalItemDuration + 100);
      }
    }

    if (burgerBtn) burgerBtn.addEventListener("click", toggleMenu);

    // Handle menu item clicks
    menuItems.forEach((item) => {
      item.addEventListener("click", async (ev) => {
        const el = ev.currentTarget;
        if (!(el instanceof Element)) return;

        // Allow default behavior for modifier keys (new tab, etc.)
        const mouseEvent = ev as MouseEvent;
        if (
          mouseEvent.metaKey ||
          mouseEvent.ctrlKey ||
          mouseEvent.shiftKey ||
          mouseEvent.altKey
        )
          return;

        ev.preventDefault();

        const href = (el.getAttribute && el.getAttribute("href")) || "";

        // Calculate common animation values
        const totalItemDuration =
          allAnimatedItems.length * itemAnimationDuration;
        // Dynamically import the navigation manager
        const { NAV_CONFIG, handleMobileNavigation } = await getNavManager();
        const menuCloseDelay = totalItemDuration + NAV_CONFIG.MENU_CLOSE_DELAY;

        // Check if the target element exists on the current page
        let targetExists = false;
        if (href.includes("#")) {
          const id = href.split("#")[1];
          if (id && document.getElementById(id)) {
            targetExists = true;
          }
        }

        // We only use the specialized navigation manager if we are scrolling to an existing element on the current page
        if (targetExists && (href.startsWith("#") || href.startsWith("/#"))) {
          // Use NavigationManager with menu close coordination for hash links
          handleMobileNavigation(
            href,
            () => {
              if (isMenuOpen) toggleMenu();
            },
            { menuCloseDelay },
          );
        } else {
          // Check if it's the current page (without hash)
          const normalize = (p: string) => {
            let path = p.split("#")[0].split("?")[0];
            if (path.endsWith("/") && path.length > 1) path = path.slice(0, -1);
            if (!path.startsWith("/")) path = "/" + path;
            return path;
          };
          const currentPath = normalize(window.location.pathname);
          const normalizedHref = normalize(href);
          const isCurrentPage = normalizedHref === currentPath;

          if (isCurrentPage && !href.includes("#")) {
            handleMobileNavigation(
              href,
              () => {
                if (isMenuOpen) toggleMenu();
              },
              { menuCloseDelay },
            );
            return;
          }

          // Handle standard page navigation (external links or cross-page hash links)
          if (isMenuOpen) toggleMenu();

          // Wait for menu close animation before navigating
          setTimeout(async () => {
            // Dynamically import navigate to avoid load-time dependencies if not needed
            const { navigate } = await import("astro:transitions/client");
            navigate(href);
          }, menuCloseDelay);
        }
      });
    });

    // Handle logo click
    if (logo) {
      logo.addEventListener("click", async (e) => {
        e.preventDefault();

        // Calculate delay based on menu animation
        const totalItemDuration =
          allAnimatedItems.length * itemAnimationDuration;
        const { NAV_CONFIG, handleMobileNavigation } = await getNavManager();
        const menuCloseDelay = totalItemDuration + NAV_CONFIG.MENU_CLOSE_DELAY;

        // Use NavigationManager for logo navigation
        handleMobileNavigation(
          "/#hero",
          () => {
            if (isMenuOpen) toggleMenu();
          },
          { menuCloseDelay },
        );
      });
    }

    // Listen for active nav updates from NavigationManager

    // ESC key to close
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isMenuOpen) {
        e.preventDefault();
        toggleMenu();
      }
    });

    /**
     * Configura el focus trap para el menú móvil.
     * Asegura que el foco permanezca dentro del menú cuando está abierto,
     * creando un loop de navegación con Tab. El usuario siempre puede escapar con ESC.
     *
     * @returns {void}
     */
    function setupFocusTrap(): void {
      if (!overlay) return;

      const focusableElements = overlay.querySelectorAll(
        'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])',
      );

      if (focusableElements.length === 0) return;

      const firstFocusable = focusableElements[0] as HTMLElement;
      const lastFocusable = focusableElements[
        focusableElements.length - 1
      ] as HTMLElement;

      // Handle Tab key to create focus loop
      overlay.addEventListener("keydown", (e) => {
        if (!isMenuOpen) return;

        if (e.key === "Tab") {
          // Shift + Tab (backwards)
          if (e.shiftKey) {
            if (document.activeElement === firstFocusable) {
              e.preventDefault();
              lastFocusable.focus();
            }
          }
          // Tab (forwards)
          else {
            if (document.activeElement === lastFocusable) {
              e.preventDefault();
              firstFocusable.focus();
            }
          }
        }
      });
    }

    setupFocusTrap();

    /**
     * Handle Enter and Space keys on menu items for better keyboard support
     */
    menuItems.forEach((item) => {
      item.addEventListener("keydown", (e) => {
        const keyEvent = e as KeyboardEvent;

        // Space key should activate links (Enter already works by default)
        if (keyEvent.key === " " || keyEvent.key === "Spacebar") {
          keyEvent.preventDefault();
          (item as HTMLElement).click();
        }
      });
    });
  });
</script>

<style>
  /* Hamburger button - fixed position */
  .mobilemenu-burger {
    position: fixed;
    right: 12px;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    cursor: pointer;
    z-index: var(--z-mobile-burger);
    -webkit-tap-highlight-color: transparent;
  }

  .mobilemenu-burger:focus-visible {
    outline: 2px solid var(--cyan-300);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }

  .mobilemenu-burger-icon {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: end;
    width: 24px;
    height: 18px;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mobilemenu-burger-icon .line {
    height: 2px;
    background: currentColor;
    transition:
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .line:nth-child(1) {
    width: 100%;
  }

  .line:nth-child(2) {
    width: 80%;
  }

  .line:nth-child(3) {
    width: 60%;
  }

  /* Animated hamburger when menu is open */
  .mobilemenu-burger-icon.active {
    width: 80%;
  }

  .mobilemenu-burger-icon.active .line:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
    width: 80%;
  }

  .mobilemenu-burger-icon.active .line:nth-child(2) {
    opacity: 0;
    width: 80%;
  }

  .mobilemenu-burger-icon.active .line:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
    width: 80%;
  }

  /* Full-screen overlay */
  .mobilemenu-overlay {
    position: fixed;
    top: -20px;
    left: -20px;
    width: 120vw;
    height: 120vh;
    height: 120dvh;
    z-index: var(--z-mobile-menu);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    background: var(--primary-blue);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    padding: 0;
  }

  .mobilemenu-overlay.visible {
    transform: scaleY(1);
  }

  /* Logo header - fixed position top left */
  .mobilemenu-header {
    position: absolute;
    top: 35px;
    left: 35px;
    width: 100%;
    padding: 0;
    z-index: var(--z-base);
  }

  .mobilemenu-logo {
    display: inline-block;
    line-height: 0;
    cursor: pointer;
  }

  /* .mobilemenu-logo:focus-visible {
    outline: 2px solid var(--cyan-300);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }

  .mobilemenu-logo img {
    display: block;
    width: 140px;
    height: auto;
  } */

  /* Menu items container - positioned from top */
  .mobilemenu-items {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    min-height: 100vh;
    min-height: 100dvh;
    gap: 1rem;
    margin-top: 0;
    padding-top: 120px;
    padding-right: 5rem;
  }

  /* Navigation list */
  .mobilemenu-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  /* Menu items */
  .mobilemenu-item {
    font-size: var(--font-size-subtitle);
    font-weight: 400;
    text-decoration: none;
    opacity: 0;
    transform: translateY(10px);
    transition:
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      color 0.3s ease;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mobilemenu-item:hover,
  .mobilemenu-item:focus-visible {
    color: var(--cyan-300, #53eafd);
  }

  .mobilemenu-item[aria-current="page"] {
    color: var(--cyan-300, #53eafd);
    font-weight: 600;
  }

  .mobilemenu-item:focus-visible {
    outline: 1px solid var(--cyan-300);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }

  /* CTA wrapper and button */
  .mobilemenu-cta-wrapper {
    margin-top: 2rem;
  }

  .mobilemenu-cta {
    opacity: 0;
    transform: translateY(10px);
    transition:
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Hide on desktop */
  @media (min-width: 1024px) {
    .mobilemenu-burger,
    .mobilemenu-overlay {
      display: none;
    }
  }

  /* Respect reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .mobilemenu-burger-icon,
    .mobilemenu-overlay,
    .mobilemenu-logo,
    .mobilemenu-item,
    .mobilemenu-cta {
      transition: none;
    }
  }
</style>
