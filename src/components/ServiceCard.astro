---
import { Image } from "astro:assets";
import Button from "./ui/Button.astro";

export interface Props {
  title: string;
  description: string;
  image?: ImageMetadata;
  video?: string;
  cta?: string;
  ctaHref?: string;
  className?: string;
}

const {
  title,
  description,
  image,
  video,
  cta = "Más info",
  ctaHref = "/#",
  className = "",
} = Astro.props;
---

<div
  class={`card-layout outer-glow-fx rounded-3xl md:rounded-4xl bg-(--primary-blue) font-sans font-light `}
  class:list={[className]}
>
  <div class="flex flex-col gap-4">
    <div class="card-image">
      {
        image && !video && (
          <Image
            src={image}
            alt={`Imagen representativa de ${title}`}
            width={480}
            height={220}
            widths={[400, 800]}
            sizes="(max-width: 768px) 100vw, 480px"
            loading="lazy"
            class="w-full h-full object-cover object-center"
          />
        )
      }
      {
        video && (
          <video
            muted
            loop
            playsinline
            preload="none"
            poster={image?.src}
            class="aspect-auto w-full object-cover object-center lazy-video rounded-2xl md:rounded-3xl"
          >
            <source src={video} type="video/webm" />
          </video>
        )
      }
    </div>
    <div class="card-text w-full flex flex-col gap-2.5 px-2">
      <h3 class="text-cyan-300 font-bold text-2xl md:text-3xl lg:text-[32px]">
        {title}
      </h3>
      <p class="font-light">{description}</p>
    </div>
  </div>
  <Button href={ctaHref} variant="outline" size="medium" icon="icon-arrow.svg">
    {cta}
  </Button>
</div>

<style>
  .card-layout.outer-glow-fx {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    margin: 0 auto;
    width: 100%;
    height: 100%;
    flex-wrap: nowrap;
    gap: 16px;
    padding: 8px;
    border: 2px solid var(--cz-border-color);
  }

  .card-image {
    width: 100%;
    max-height: 190px;
    overflow: hidden;
    border-radius: 20px;
  }

  /* EFECTO HOVER EN CARD - PRESERVED */
  .outer-glow-fx {
    box-shadow: 0px 0px 0px 0px #02061866;
    -webkit-box-shadow: 0px 0px 0px 0px #02061866;
    -moz-box-shadow: 0px 0px 0px 0px #02061866;
    transition: all 600ms ease-out;
  }

  .outer-glow-fx:hover {
    box-shadow: 0px 15px 25px 0px #02061866;
    -webkit-box-shadow: 0px 15px 25px 0px #02061866;
    -moz-box-shadow: 0px 15px 25px 0px #02061866;
    border-color: rgba(83, 233, 253, 0.3);
    transition: all 300ms ease-out;
  }

  /* Responsive Design */
  @media (min-width: 768px) {
    .card-layout {
      flex-direction: column;
      width: 100%;
      height: 100%;
    }
    .card-image {
      height: 190px;
    }
  }

  @media (min-width: 1024px) {
    .card-layout {
      width: 100%;
    }
  }
</style>
